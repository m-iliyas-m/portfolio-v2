---
const year = new Date().getFullYear();
const socials = [
  { label: 'GitHub', href: 'https://github.com/yourusername' },
  { label: 'LinkedIn', href: 'https://linkedin.com/in/yourusername' },
  { label: 'Twitter/X', href: 'https://twitter.com/yourusername' },
];
---
<footer class="footer">
  <div class="footer-inner">
    <span class="footer-copy">© {year} Your Name. Built with Astro. Hosted free on GitHub Pages.</span>
    <div class="footer-socials">
      {socials.map(s => <a href={s.href} target="_blank" rel="noopener">{s.label}</a>)}
    </div>
  </div>
</footer>
