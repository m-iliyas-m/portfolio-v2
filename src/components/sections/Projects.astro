---
import ProjectCard from '../ui/ProjectCard.astro';
import projects from '../../content/projects.json';
const featured = projects.filter((p: any) => p.featured);
---
<section class="projects" id="projects">
  <h2 class="section-title">Projects</h2>
  <p class="section-sub">Things I've built across data engineering, GenAI, and analytics.</p>
  <div class="projects-grid">
    {featured.map((p: any) => <ProjectCard {...p} />)}
  </div>
  <div class="projects-more">
    <a href="https://github.com/m-iliyas-m" target="_blank" rel="noopener" class="btn-secondary">
      More on GitHub →
    </a>
  </div>
</section>
