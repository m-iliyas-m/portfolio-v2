---
// Formspree — replace YOUR_FORM_ID with your free Formspree form ID
const formspreeId = "YOUR_FORM_ID";
---
<section class="contact" id="contact">
  <h2 class="section-title">Get In Touch</h2>
  <p class="section-sub">Open for data roles, freelance projects, and collaborations.</p>

  <div class="contact-grid">
    <form class="contact-form" action={`https://formspree.io/f/${formspreeId}`} method="POST">
      <input type="text" name="name" placeholder="Your name" required />
      <input type="email" name="email" placeholder="Your email" required />
      <input type="text" name="subject" placeholder="Subject" />
      <textarea name="message" rows="5" placeholder="Your message" required></textarea>
      <button type="submit" class="btn-primary">Send Message →</button>
    </form>

    <div class="contact-links">
      <a href="mailto:you@email.com" class="contact-link">📧 you@email.com</a>
      <a href="https://linkedin.com/in/yourusername" target="_blank" rel="noopener" class="contact-link">💼 LinkedIn</a>
      <a href="https://github.com/yourusername" target="_blank" rel="noopener" class="contact-link">🐙 GitHub</a>
      <a href="https://twitter.com/yourusername" target="_blank" rel="noopener" class="contact-link">🐦 Twitter/X</a>
    </div>
  </div>
</section>
